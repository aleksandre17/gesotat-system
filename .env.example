# ============================================================
#  GeoStat System — Environment Variables
# ============================================================
#  Development:   cp .env.example .env.dev   → docker-compose.dev.yml
#  Production:    cp .env.example .env.prod  → docker-compose.prod.yml
# ============================================================

# ── App Version ──────────────────────────────────────────────
APP_VERSION=0.0.1-SNAPSHOT

# ── Ports ────────────────────────────────────────────────────
API_PORT=8081
MOBILE_PORT=8082

# ── Primary Database (geostat-system) ────────────────────────
DB_PRIMARY_URL=jdbc:sqlserver://YOUR_HOST;databaseName=geostat-system;encrypt=true;trustServerCertificate=true;serverTimezone=Asia/Tbilisi;cachePrepStmts=true
DB_PRIMARY_USER=sa
DB_PRIMARY_PASS=CHANGE_ME

# ── Secondary Database (auto) ────────────────────────────────
DB_SECONDARY_URL=jdbc:sqlserver://YOUR_HOST;databaseName=auto;encrypt=true;trustServerCertificate=true;serverTimezone=Asia/Tbilisi;cachePrepStmts=true
DB_SECONDARY_USER=sa
DB_SECONDARY_PASS=CHANGE_ME

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_SECURE_64_CHAR_HEX_STRING
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=86400000

